# 줄바꿈 정규화: 저장소에는 항상 LF로 저장
* text=auto eol=lf

# 명시적 텍스트 파일
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.svg    text eol=lf
*.md     text eol=lf

# 바이너리 (줄바꿈 처리 금지)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary
*.pdf    binary
*.zip    binary
